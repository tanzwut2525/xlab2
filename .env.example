# --- LLM providers / chat ---
ANTHROPIC_API_KEY=
DEFAULT_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-sonnet-5

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1

MAX_TOOL_ITERATIONS=8

# Whether the unauthenticated /chat endpoint may call remediation tools
# (restart_deployment, scale_deployment, delete_pod). Keep this false unless
# /chat sits behind auth/network policy.
CHAT_EXPOSE_OPS_TOOLS=false

LOG_LEVEL=INFO

# --- Prometheus ---
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_TIMEOUT=10
# Optional bearer token, if your Prometheus is behind auth.
PROMETHEUS_BEARER_TOKEN=

# --- Kubernetes ---
# Leave empty to use in-cluster config (when running as a Pod) or the
# default kubeconfig location. Only needed for a non-default local kubeconfig path.
KUBECONFIG_PATH=
# Comma-separated allowlist. Empty means NO namespace may be mutated (fail closed).
K8S_ALLOWED_NAMESPACES=default
# Safety default: remediation tools log what they *would* do instead of
# calling the Kubernetes API. Set to false only once you've reviewed the
# namespace allowlist and RBAC scope in k8s/rbac.yaml.
DRY_RUN=true
MAX_SCALE_REPLICAS=10

# --- Monitoring scheduler ---
MONITOR_ENABLED=true
MONITOR_INTERVAL_SECONDS=60
MONITOR_PROVIDER=ollama
RULES_PATH=config/rules.yaml

# --- Remediation guardrails ---
MAX_REMEDIATIONS_PER_CYCLE=3
VERIFY_TIMEOUT_SECONDS=120
VERIFY_POLL_INTERVAL_SECONDS=10

# --- Notifications ---
# One of: log | slack | webhook
NOTIFIER=log
SLACK_WEBHOOK_URL=
NOTIFY_WEBHOOK_URL=
